# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (development, no setup needed)
DATABASE_URL="file:./dev.db"

# PostgreSQL (production — use with docker-compose.yml)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartdoc"

# ─── Required: AI APIs ────────────────────────────────────────────────────────
# Groq — LLM (chat) + summarization. Free tier at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Jina AI — embeddings + reranking. 1M free tokens at https://jina.ai
JINA_API_KEY=your_jina_api_key_here

# ─── Optional: Alternative AI ─────────────────────────────────────────────────
# Gemini — alternative embedder/summarizer. https://aistudio.google.com
GEMINI_API_KEY=

# ─── Optional: Async Queue ────────────────────────────────────────────────────
# Redis — enables Bull queue for background PDF processing + response caching.
# If unset, uploads are processed synchronously (fine for development).
# REDIS_URL=redis://localhost:6379

# ─── Optional: Observability ──────────────────────────────────────────────────
# Langfuse — LLM tracing, latency metrics, user feedback. https://langfuse.com
# Leave blank to disable tracing entirely.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ─── Optional: CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=*
